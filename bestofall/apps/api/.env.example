# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://bestofall:bestofall@localhost:5432/bestofall

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Firebase Admin (OTP verification) — download service account JSON from
# Firebase console > Project Settings > Service Accounts, and either point
# GOOGLE_APPLICATION_CREDENTIALS at the file or paste the values below.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Set to "true" to bypass Firebase and use the built-in dev OTP (123456)
AUTH_DEV_MODE=true

# Google Maps / Places (distance, geocoding, autocomplete)
GOOGLE_MAPS_API_KEY=

# Search cache TTL (seconds)
SEARCH_CACHE_TTL=120

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
