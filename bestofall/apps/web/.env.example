# Base URL of the BestOfAll API (apps/api)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Google Maps JS API key — used client-side for address autocomplete & maps.
# Restrict this key to your domain in the Google Cloud Console.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Firebase web config — used client-side for phone OTP sign-in (Firebase Auth).
# Leave blank while apps/api has AUTH_DEV_MODE=true.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
